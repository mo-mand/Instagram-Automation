# Database
DATABASE_URL="postgresql://user:password@localhost:5432/instabot"

# Redis
REDIS_URL="redis://localhost:6379"

# Meta / Instagram
INSTAGRAM_APP_ID="your_app_id"
INSTAGRAM_APP_SECRET="your_app_secret"
INSTAGRAM_ACCESS_TOKEN="your_long_lived_user_token"
INSTAGRAM_ACCOUNT_ID="your_ig_business_account_id"
WEBHOOK_VERIFY_TOKEN="your_self_defined_secret_string"

# Admin Panel Security
ADMIN_API_KEY="generate_a_strong_random_string_here"

# App
PORT=3000
PUBLIC_BASE_URL="https://your-server.com"
TIMEZONE="America/Toronto"
NODE_ENV="development"
