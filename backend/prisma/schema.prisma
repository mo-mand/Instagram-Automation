generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WhitelistedAccount {
  id              String   @id @default(cuid())
  instagramUserId String   @unique
  username        String?
  addedAt         DateTime @default(now())
  isActive        Boolean  @default(true)

  receivedPosts ReceivedPost[]
}

model ReceivedPost {
  id         String   @id @default(cuid())
  receivedAt DateTime @default(now())

  senderId String
  sender   WhitelistedAccount @relation(fields: [senderId], references: [instagramUserId])

  dmMessageId String  @unique
  mediaType   String  // "IMAGE" | "VIDEO" | "CAROUSEL"
  mediaUrl    String
  localFile   String?
  caption     String?
  rawPayload  String  // JSON stringified

  status       String    @default("PENDING")
  scheduledFor DateTime?
  jobId        String?

  instagramPostId String?
  postedAt        DateTime?

  activityLogs ActivityLog[]

  @@index([status])
  @@index([scheduledFor])
  @@index([senderId])
}

model AppConfig {
  id             Int      @id @default(1)
  targetPageId   String   @default("")
  maxPostsPerDay Int      @default(3)
  timezone       String   @default("America/Toronto")
  updatedAt      DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  level      String   @default("INFO") // "INFO" | "WARN" | "ERROR"
  event      String
  message    String
  postId     String?
  post       ReceivedPost? @relation(fields: [postId], references: [id])
  meta       String?  // JSON stringified

  @@index([occurredAt(sort: Desc)])
  @@index([event])
}
